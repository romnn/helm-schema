{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "helm_template",
      "camelcase": "HelmTemplate",
      "title": "Helm Template",
      "scope": "source.helm-template",
      "file-types": [
        "yml",
        "yaml"
      ],
      "highlights": "queries/highlights.scm",
      "class-name": "TreeSitterHelmTemplate",
      "injection-regex": "^(helm|helm[-_]template)$"
    }
  ],
  "metadata": {
    "version": "0.7.2",
    "license": "MIT",
    "description": "Helm template grammar for tree-sitter",
    "authors": [
      {
        "name": "Ika",
        "email": "ikatyang@gmail.com",
        "url": "https://github.com/ikatyang"
      },
      {
        "name": "Amaan Qureshi",
        "email": "amaanq12@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/romnn/helm-schema"
    }
  },
  "bindings": {
    "rust": true
  }
}
