{
    "name": "tree-sitter-go-template",
    "version": "0.19.5",
    "description": "Golang template grammar for tree-sitter",
    "private": true,
    "keywords": [
        "parser",
        "json",
        "go-template",
        "helm"
    ],
    "author": "Nikita Galaiko",
    "license": "MIT",
    "devDependencies": {
        "prettier": "^3.9.4",
        "tree-sitter-cli": "^0.26.10"
    },
    "scripts": {
        "generate": "tree-sitter generate && npm run generate:helm",
        "generate:helm": "cd dialects/helm && tree-sitter generate",
        "format": "prettier --write grammar.js make_grammar.js dialects/helm/grammar.js",
        "test": "tree-sitter test",
        "parse": "tree-sitter parse",
        "highlight": "tree-sitter highlight"
    }
}
