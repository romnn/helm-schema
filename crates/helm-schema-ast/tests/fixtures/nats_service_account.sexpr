(template
  (function_call
    function: (identifier :text "include")
    arguments: (argument_list
      (interpreted_string_literal :text "\"nats.defaultValues\"")
      (dot :text ".")
    )
  )
  (with_action
    condition: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "serviceAccount")
    )
    consequence: (if_action
      condition: (field
        name: (identifier :text "enabled")
      )
      consequence: (function_call
        function: (identifier :text "include")
        arguments: (argument_list
          (interpreted_string_literal :text "\"nats.loadMergePatch\"")
          (parenthesized_pipeline
            (function_call
              function: (identifier :text "merge")
              arguments: (argument_list
                (parenthesized_pipeline
                  (function_call
                    function: (identifier :text "dict")
                    arguments: (argument_list
                      (interpreted_string_literal :text "\"file\"")
                      (interpreted_string_literal :text "\"service-account.yaml\"")
                      (interpreted_string_literal :text "\"ctx\"")
                      (variable :text "$")
                    )
                  )
                )
                (dot :text ".")
              )
            )
          )
        )
      )
    )
  )
)
