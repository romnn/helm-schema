(stream
  (comment :text "{{- /*\nCopyright VMware, Inc.\nSPDX-License-Identifier: APACHE-2.0\n*/}}")
  (document
    (block_node
      (block_mapping
        (helm_template :text "{{- $host := include \"postgresql.v1.primary.fullname\" . }}")
        (helm_template :text "{{- $port := include \"postgresql.v1.service.port\" . }}")
        (helm_template :text "{{- $customUser := include \"postgresql.v1.username\" . }}")
        (helm_template :text "{{- $postgresPassword := include \"common.secrets.lookup\" (dict \"secret\" (include \"postgresql.v1.secretName\" .) \"key\" (coalesce .Values.global.postgresql.auth.secretKeys.adminPasswordKey .Values.auth.secretKeys.adminPasswordKey) \"defaultValue\" (ternary (coalesce .Values.global.postgresql.auth.password .Values.auth.password .Values.global.postgresql.auth.postgresPassword .Values.auth.postgresPassword) (coalesce .Values.global.postgresql.auth.postgresPassword .Values.auth.postgresPassword) (or (empty $customUser) (eq $customUser \"postgres\"))) \"context\" $) | trimAll \"\\\"\" | b64dec }}")
        (comment :text "{{- if and (not $postgresPassword) .Values.auth.enablePostgresUser }}")
        (helm_template :text "{{- $postgresPassword = randAlphaNum 10 }}")
        (comment :text "{{- end }}")
        (helm_template :text "{{- $replicationPassword := \"\" }}")
        (comment :text "{{- if eq .Values.architecture \"replication\" }}")
        (helm_template :text "{{- $replicationPassword = include \"common.secrets.passwords.manage\" (dict \"secret\" (include \"postgresql.v1.secretName\" .) \"key\" (coalesce .Values.global.postgresql.auth.secretKeys.replicationPasswordKey .Values.auth.secretKeys.replicationPasswordKey) \"providedValues\" (list \"auth.replicationPassword\") \"context\" $) | trimAll \"\\\"\" | b64dec }}")
        (comment :text "{{- end }}")
        (helm_template :text "{{- $ldapPassword := \"\" }}")
        (comment :text "{{- if and .Values.ldap.enabled (or .Values.ldap.bind_password .Values.ldap.bindpw) }}")
        (helm_template :text "{{- $ldapPassword = coalesce .Values.ldap.bind_password .Values.ldap.bindpw }}")
        (comment :text "{{- end }}")
        (helm_template :text "{{- $password := \"\" }}")
        (comment :text "{{- if and (not (empty $customUser)) (ne $customUser \"postgres\") }}")
        (helm_template :text "{{- $password = include \"common.secrets.passwords.manage\" (dict \"secret\" (include \"postgresql.v1.secretName\" .) \"key\" (coalesce .Values.global.postgresql.auth.secretKeys.userPasswordKey .Values.auth.secretKeys.userPasswordKey) \"providedValues\" (list \"global.postgresql.auth.password\" \"auth.password\") \"context\" $) | trimAll \"\\\"\" | b64dec }}")
        (comment :text "{{- end }}")
        (helm_template :text "{{- $database := include \"postgresql.v1.database\" . }}")
        (comment :text "{{- if (include \"postgresql.v1.createSecret\" .) }}")
        (block_mapping_pair
          key: (flow_node
            (plain_scalar
              (string_scalar :text "apiVersion")
            )
          )
          value: (flow_node
            (plain_scalar
              (string_scalar :text "v1")
            )
          )
        )
        (block_mapping_pair
          key: (flow_node
            (plain_scalar
              (string_scalar :text "kind")
            )
          )
          value: (flow_node
            (plain_scalar
              (string_scalar :text "Secret")
            )
          )
        )
        (block_mapping_pair
          key: (flow_node
            (plain_scalar
              (string_scalar :text "metadata")
            )
          )
          value: (block_node
            (block_mapping
              (block_mapping_pair
                key: (flow_node
                  (plain_scalar
                    (string_scalar :text "name")
                  )
                )
                value: (helm_template :text "{{ include \"common.names.fullname\" . }}")
              )
              (block_mapping_pair
                key: (flow_node
                  (plain_scalar
                    (string_scalar :text "namespace")
                  )
                )
                value: (helm_template :text "{{ .Release.Namespace | quote }}")
              )
              (block_mapping_pair
                key: (flow_node
                  (plain_scalar
                    (string_scalar :text "labels")
                  )
                )
                value: (helm_template :text "{{- include \"common.labels.standard\" ( dict \"customLabels\" .Values.commonLabels \"context\" $ ) | nindent 4 }}")
              )
              (comment :text "{{- if .Values.commonAnnotations }}")
              (block_mapping_pair
                key: (flow_node
                  (plain_scalar
                    (string_scalar :text "annotations")
                  )
                )
                value: (helm_template :text "{{- include \"common.tplvalues.render\" ( dict \"value\" .Values.commonAnnotations \"context\" $ ) | nindent 4 }}")
              )
              (comment :text "{{- end }}")
            )
          )
        )
        (block_mapping_pair
          key: (flow_node
            (plain_scalar
              (string_scalar :text "type")
            )
          )
          value: (flow_node
            (plain_scalar
              (string_scalar :text "Opaque")
            )
          )
        )
        (block_mapping_pair
          key: (flow_node
            (plain_scalar
              (string_scalar :text "data")
            )
          )
          (comment :text "{{- if $postgresPassword }}")
          value: (block_node
            (block_mapping
              (block_mapping_pair
                key: (flow_node
                  (plain_scalar
                    (string_scalar :text "postgres-password")
                  )
                )
                value: (helm_template :text "{{ $postgresPassword | b64enc | quote }}")
              )
              (comment :text "{{- end }}")
              (comment :text "{{- if $password }}")
              (block_mapping_pair
                key: (flow_node
                  (plain_scalar
                    (string_scalar :text "password")
                  )
                )
                value: (helm_template :text "{{ $password | b64enc | quote }}")
              )
              (comment :text "{{- end }}")
              (comment :text "{{- if $replicationPassword }}")
              (block_mapping_pair
                key: (flow_node
                  (plain_scalar
                    (string_scalar :text "replication-password")
                  )
                )
                value: (helm_template :text "{{ $replicationPassword | b64enc | quote }}")
              )
              (comment :text "{{- end }}")
              (comment :text "# We don't auto-generate LDAP password when it's not provided as we do for other passwords")
              (comment :text "{{- if and .Values.ldap.enabled (or .Values.ldap.bind_password .Values.ldap.bindpw) }}")
              (block_mapping_pair
                key: (flow_node
                  (plain_scalar
                    (string_scalar :text "ldap-password")
                  )
                )
                value: (helm_template :text "{{ $ldapPassword  | b64enc | quote }}")
              )
              (comment :text "{{- end }}")
              (comment :text "{{- end }}")
              (comment :text "{{- if .Values.serviceBindings.enabled }}")
              (comment :text "{{- if $postgresPassword }}")
            )
          )
        )
      )
    )
