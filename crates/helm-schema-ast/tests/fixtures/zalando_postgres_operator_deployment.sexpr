(template
  (text :text "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  labels:\n    app.kubernetes.io/name:")
  (template_action
    name: (interpreted_string_literal :text "\"postgres-operator.name\"")
    argument: (dot :text ".")
  )
  (text :text "helm.sh/chart:")
  (template_action
    name: (interpreted_string_literal :text "\"postgres-operator.chart\"")
    argument: (dot :text ".")
  )
  (text :text "app.kubernetes.io/managed-by:")
  (selector_expression
    operand: (field
      name: (identifier :text "Release")
    )
    field: (field_identifier :text "Service")
  )
  (text :text "app.kubernetes.io/instance:")
  (selector_expression
    operand: (field
      name: (identifier :text "Release")
    )
    field: (field_identifier :text "Name")
  )
  (text :text "name:")
  (template_action
    name: (interpreted_string_literal :text "\"postgres-operator.fullname\"")
    argument: (dot :text ".")
  )
  (text :text "namespace:")
  (selector_expression
    operand: (field
      name: (identifier :text "Release")
    )
    field: (field_identifier :text "Namespace")
  )
  (text :text "spec:\n  replicas: 1\n  selector:\n    matchLabels:\n      app.kubernetes.io/name:")
  (template_action
    name: (interpreted_string_literal :text "\"postgres-operator.name\"")
    argument: (dot :text ".")
  )
  (text :text "app.kubernetes.io/instance:")
  (selector_expression
    operand: (field
      name: (identifier :text "Release")
    )
    field: (field_identifier :text "Name")
  )
  (text :text "template:\n    metadata:\n      annotations:")
  (if_action
    condition: (function_call
      function: (identifier :text "eq")
      arguments: (argument_list
        (selector_expression
          operand: (field
            name: (identifier :text "Values")
          )
          field: (field_identifier :text "configTarget")
        )
        (interpreted_string_literal :text "\"ConfigMap\"")
      )
    )
    consequence: (text :text "checksum/config:")
    consequence: (chained_pipeline
      (function_call
        function: (identifier :text "include")
        arguments: (argument_list
          (parenthesized_pipeline
            (function_call
              function: (identifier :text "print")
              arguments: (argument_list
                (selector_expression
                  operand: (selector_expression
                    operand: (variable :text "$")
                    field: (field_identifier :text "Template")
                  )
                  field: (field_identifier :text "BasePath")
                )
                (interpreted_string_literal :text "\"/configmap.yaml\"")
              )
            )
          )
          (dot :text ".")
        )
      )
      (function_call
        function: (identifier :text "sha256sum")
      )
    )
    alternative: (text :text "checksum/config:")
    alternative: (chained_pipeline
      (function_call
        function: (identifier :text "include")
        arguments: (argument_list
          (parenthesized_pipeline
            (function_call
              function: (identifier :text "print")
              arguments: (argument_list
                (selector_expression
                  operand: (selector_expression
                    operand: (variable :text "$")
                    field: (field_identifier :text "Template")
                  )
                  field: (field_identifier :text "BasePath")
                )
                (interpreted_string_literal :text "\"/operatorconfiguration.yaml\"")
              )
            )
          )
          (dot :text ".")
        )
      )
      (function_call
        function: (identifier :text "sha256sum")
      )
    )
  )
  (if_action
    condition: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "podAnnotations")
    )
    consequence: (chained_pipeline
      (function_call
        function: (identifier :text "toYaml")
        arguments: (argument_list
          (selector_expression
            operand: (field
              name: (identifier :text "Values")
            )
            field: (field_identifier :text "podAnnotations")
          )
        )
      )
      (function_call
        function: (identifier :text "indent")
        arguments: (argument_list
          (int_literal :text "8")
        )
      )
    )
  )
  (text :text "labels:\n        app.kubernetes.io/name:")
  (template_action
    name: (interpreted_string_literal :text "\"postgres-operator.name\"")
    argument: (dot :text ".")
  )
  (text :text "app.kubernetes.io/instance:")
  (selector_expression
    operand: (field
      name: (identifier :text "Release")
    )
    field: (field_identifier :text "Name")
  )
  (if_action
    condition: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "podLabels")
    )
    consequence: (chained_pipeline
      (function_call
        function: (identifier :text "toYaml")
        arguments: (argument_list
          (selector_expression
            operand: (field
              name: (identifier :text "Values")
            )
            field: (field_identifier :text "podLabels")
          )
        )
      )
      (function_call
        function: (identifier :text "indent")
        arguments: (argument_list
          (int_literal :text "8")
        )
      )
    )
  )
  (text :text "spec:\n      serviceAccountName:")
  (function_call
    function: (identifier :text "include")
    arguments: (argument_list
      (interpreted_string_literal :text "\"postgres-operator.serviceAccountName\"")
      (dot :text ".")
    )
  )
  (text :text "containers:\n      - name:")
  (selector_expression
    operand: (field
      name: (identifier :text "Chart")
    )
    field: (field_identifier :text "Name")
  )
  (text :text "image: \"")
  (selector_expression
    operand: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "image")
    )
    field: (field_identifier :text "registry")
  )
  (text :text "/")
  (selector_expression
    operand: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "image")
    )
    field: (field_identifier :text "repository")
  )
  (text :text ":")
  (selector_expression
    operand: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "image")
    )
    field: (field_identifier :text "tag")
  )
  (text :text "\"\n        imagePullPolicy:")
  (selector_expression
    operand: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "image")
    )
    field: (field_identifier :text "pullPolicy")
  )
  (text :text "env:")
  (if_action
    condition: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "enableJsonLogging")
    )
    consequence: (text :text "- name: ENABLE_JSON_LOGGING\n          value: \"true\"")
  )
  (if_action
    condition: (function_call
      function: (identifier :text "eq")
      arguments: (argument_list
        (selector_expression
          operand: (field
            name: (identifier :text "Values")
          )
          field: (field_identifier :text "configTarget")
        )
        (interpreted_string_literal :text "\"ConfigMap\"")
      )
    )
    consequence: (text :text "- name: CONFIG_MAP_NAME\n          value:")
    consequence: (template_action
      name: (interpreted_string_literal :text "\"postgres-operator.fullname\"")
      argument: (dot :text ".")
    )
    alternative: (text :text "- name: POSTGRES_OPERATOR_CONFIGURATION_OBJECT\n          value:")
    alternative: (template_action
      name: (interpreted_string_literal :text "\"postgres-operator.fullname\"")
      argument: (dot :text ".")
    )
  )
  (if_action
    condition: (selector_expression
      operand: (selector_expression
        operand: (field
          name: (identifier :text "Values")
        )
        field: (field_identifier :text "controllerID")
      )
      field: (field_identifier :text "create")
    )
    consequence: (text :text "- name: CONTROLLER_ID\n          value:")
    consequence: (template_action
      name: (interpreted_string_literal :text "\"postgres-operator.controllerID\"")
      argument: (dot :text ".")
    )
  )
  (if_action
    condition: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "extraEnvs")
    )
    consequence: (chained_pipeline
      (function_call
        function: (identifier :text "toYaml")
        arguments: (argument_list
          (selector_expression
            operand: (field
              name: (identifier :text "Values")
            )
            field: (field_identifier :text "extraEnvs")
          )
        )
      )
      (function_call
        function: (identifier :text "indent")
        arguments: (argument_list
          (int_literal :text "8")
        )
      )
    )
  )
  (text :text "resources:")
  (chained_pipeline
    (function_call
      function: (identifier :text "toYaml")
      arguments: (argument_list
        (selector_expression
          operand: (field
            name: (identifier :text "Values")
          )
          field: (field_identifier :text "resources")
        )
      )
    )
    (function_call
      function: (identifier :text "indent")
      arguments: (argument_list
        (int_literal :text "10")
      )
    )
  )
  (text :text "securityContext:")
  (chained_pipeline
    (function_call
      function: (identifier :text "toYaml")
      arguments: (argument_list
        (selector_expression
          operand: (field
            name: (identifier :text "Values")
          )
          field: (field_identifier :text "securityContext")
        )
      )
    )
    (function_call
      function: (identifier :text "indent")
      arguments: (argument_list
        (int_literal :text "10")
      )
    )
  )
  (if_action
    condition: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "readinessProbe")
    )
    consequence: (text :text "readinessProbe:\n          httpGet:\n            path: /readyz\n            port:")
    consequence: (selector_expression
      operand: (selector_expression
        operand: (field
          name: (identifier :text "Values")
        )
        field: (field_identifier :text "configLoggingRestApi")
      )
      field: (field_identifier :text "api_port")
    )
    consequence: (text :text "initialDelaySeconds:")
    consequence: (selector_expression
      operand: (selector_expression
        operand: (field
          name: (identifier :text "Values")
        )
        field: (field_identifier :text "readinessProbe")
      )
      field: (field_identifier :text "initialDelaySeconds")
    )
    consequence: (text :text "periodSeconds:")
    consequence: (selector_expression
      operand: (selector_expression
        operand: (field
          name: (identifier :text "Values")
        )
        field: (field_identifier :text "readinessProbe")
      )
      field: (field_identifier :text "periodSeconds")
    )
  )
  (if_action
    condition: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "imagePullSecrets")
    )
    consequence: (text :text "imagePullSecrets:")
    consequence: (chained_pipeline
      (function_call
        function: (identifier :text "toYaml")
        arguments: (argument_list
          (selector_expression
            operand: (field
              name: (identifier :text "Values")
            )
            field: (field_identifier :text "imagePullSecrets")
          )
        )
      )
      (function_call
        function: (identifier :text "indent")
        arguments: (argument_list
          (int_literal :text "8")
        )
      )
    )
  )
  (text :text "affinity:")
  (chained_pipeline
    (function_call
      function: (identifier :text "toYaml")
      arguments: (argument_list
        (selector_expression
          operand: (field
            name: (identifier :text "Values")
          )
          field: (field_identifier :text "affinity")
        )
      )
    )
    (function_call
      function: (identifier :text "indent")
      arguments: (argument_list
        (int_literal :text "8")
      )
    )
  )
  (text :text "nodeSelector:")
  (chained_pipeline
    (function_call
      function: (identifier :text "toYaml")
      arguments: (argument_list
        (selector_expression
          operand: (field
            name: (identifier :text "Values")
          )
          field: (field_identifier :text "nodeSelector")
        )
      )
    )
    (function_call
      function: (identifier :text "indent")
      arguments: (argument_list
        (int_literal :text "8")
      )
    )
  )
  (text :text "tolerations:")
  (chained_pipeline
    (function_call
      function: (identifier :text "toYaml")
      arguments: (argument_list
        (selector_expression
          operand: (field
            name: (identifier :text "Values")
          )
          field: (field_identifier :text "tolerations")
        )
      )
    )
    (function_call
      function: (identifier :text "indent")
      arguments: (argument_list
        (int_literal :text "8")
      )
    )
  )
  (if_action
    condition: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "priorityClassName")
    )
    consequence: (text :text "priorityClassName:")
    consequence: (selector_expression
      operand: (field
        name: (identifier :text "Values")
      )
      field: (field_identifier :text "priorityClassName")
    )
  )
)
