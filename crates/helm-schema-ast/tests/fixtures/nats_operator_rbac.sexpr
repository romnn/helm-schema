                    (block_mapping_pair
                      key: (flow_node
                        (plain_scalar
                          (string_scalar :text "name")
                        )
                      )
                      value: (flow_node
                        (plain_scalar
                          (string_scalar :text "nats-operator")
                        )
                      )
                    )
                    (block_mapping_pair
                      key: (flow_node
                        (plain_scalar
                          (string_scalar :text "namespace")
                        )
                      )
                      value: (helm_template :text "{{ .Release.Namespace }}")
                    )
                    (comment :text "{{- end }}")
                  )
                )
              )
            )
          )
        )
      )
    )
  )
)
