                },
                "postgresPassword": {
                  "type": "string"
                },
                "secretKeys": {
                  "additionalProperties": false,
                  "properties": {
                    "adminPasswordKey": {
                      "type": "string"
                    },
                    "replicationPasswordKey": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "userPasswordKey": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  "type": "object"
                },
                "username": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "type": "object"
            },
            "service": {
              "additionalProperties": false,
              "properties": {
                "ports": {
                  "additionalProperties": false,
                  "properties": {
                    "postgresql": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        }
      },
