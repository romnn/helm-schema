      "type": [
        "string",
        "null"
      ]
    },
    "namespaceOverride": {
      "type": [
        "string",
        "null"
      ]
    },
    "primary": {
      "additionalProperties": false,
      "properties": {
        "name": {},
        "service": {
          "additionalProperties": false,
          "properties": {
            "ports": {
