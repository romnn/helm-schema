            "replicationPasswordKey": {
              "type": [
                "string",
                "null"
              ]
            },
            "userPasswordKey": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "type": "object"
        },
        "usePasswordFiles": {
          "type": "boolean"
