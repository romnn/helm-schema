              "type": "null"
            },
            {
              "type": "string"
            }
          ]
        },
        "enablePostgresUser": {
          "type": "boolean"
        },
        "existingSecret": {
          "type": [
            "string",
            "null"
          ]
        },
        "password": {
          "type": [
            "string",
            "null"
          ]
        },
        "postgresPassword": {
          "type": "string"
        },
        "replicationPassword": {
          "type": [
            "string",
            "null"
          ]
        },
        "replicationUsername": {
          "type": "string"
