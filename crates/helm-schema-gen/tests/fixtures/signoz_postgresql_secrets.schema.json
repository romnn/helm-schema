{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "serviceBindings": {
                "properties": {
                  "enabled": {
                    "anyOf": [
                      {
                        "const": true
                      },
                      {
                        "not": {
                          "const": 0
                        },
                        "type": "number"
                      },
                      {
                        "minLength": 1,
                        "type": "string"
                      },
                      {
                        "minItems": 1,
                        "type": "array"
                      },
                      {
                        "minProperties": 1,
                        "type": "object"
                      }
                    ]
                  }
                },
                "required": [
                  "enabled"
                ],
                "type": "object"
              }
            },
            "required": [
              "serviceBindings"
            ],
            "type": "object"
          },
          {
            "properties": {
              "architecture": {
                "enum": [
                  "replication"
                ]
              }
            },
            "required": [
              "architecture"
            ],
            "type": "object"
          }
        ]
      },
      "then": {
        "properties": {
          "primary": {
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "type": "object"
          }
        },
        "type": "object"
      }
    }
  ],
  "properties": {
