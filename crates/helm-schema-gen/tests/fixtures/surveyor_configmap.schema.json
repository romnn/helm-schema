{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "config": {
            "properties": {
              "jetstream": {
                "properties": {
                  "enabled": {
                    "anyOf": [
                      {
                        "const": true
                      },
                      {
                        "not": {
                          "const": 0
                        },
                        "type": "number"
                      },
                      {
                        "minLength": 1,
                        "type": "string"
                      },
                      {
                        "minItems": 1,
                        "type": "array"
                      },
                      {
                        "minProperties": 1,
                        "type": "object"
                      }
                    ]
                  }
                },
                "required": [
                  "enabled"
                ],
                "type": "object"
              }
            },
            "required": [
              "jetstream"
            ],
            "type": "object"
          }
        },
        "required": [
          "config"
        ],
        "type": "object"
      },
      "then": {
        "properties": {
          "nameOverride": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "type": "object"
      }
    }
  ],
  "properties": {
    "config": {
      "additionalProperties": false,
      "properties": {
        "jetstream": {
          "additionalProperties": false,
          "properties": {
            "accounts": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "tls": {
                    "additionalProperties": false,
                    "properties": {
                      "ca": {
                        "type": "string"
                      },
                      "cert": {
                        "type": "string"
                      },
                      "key": {
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "username": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "type": "array"
            },
            "enabled": {
              "type": "boolean"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "fullnameOverride": {
      "type": [
        "string",
        "null"
      ]
    },
    "global": {
      "additionalProperties": false,
      "properties": {
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Map of string keys and values that can be used to organize and categorize (scope and select) objects. May match selectors of replication controllers and services. More info: https://kubernetes.io/docs/concepts/overview/working-with-objects/labels",
          "properties": {},
          "type": "object"
        }
      },
      "type": "object"
    },
    "nameOverride": {}
  },
  "type": "object"
}
