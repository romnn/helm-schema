{
  "$defs": {
    "helm-truthy": {
      "anyOf": [
        {
          "const": true
        },
        {
          "not": {
            "const": 0
          },
          "type": "number"
        },
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "minItems": 1,
          "type": "array"
        },
        {
          "minProperties": 1,
          "type": "object"
        }
      ]
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "anyOf": [
          {
            "not": {
              "properties": {
                "rbac": {
                  "properties": {
                    "create": {}
                  },
                  "required": [
                    "create"
                  ],
                  "type": "object"
                }
              },
              "required": [
                "rbac"
              ],
              "type": "object"
            }
          },
          {
            "properties": {
              "rbac": {
                "properties": {
                  "create": {
                    "$ref": "#/$defs/helm-truthy"
                  }
                },
                "required": [
                  "create"
                ],
                "type": "object"
              }
            },
            "required": [
              "rbac"
            ],
            "type": "object"
          }
        ]
      },
      "then": {
        "properties": {
          "serviceAccount": {
            "properties": {
              "name": {
                "description": "The name of the ServiceAccount to use.\nIf not set and create is true, a name is generated using the fullname template",
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "type": "object"
          }
        },
        "type": "object"
      }
    }
  ],
  "properties": {
    "affinity": {
      "additionalProperties": {},
      "description": "Affinity for pod assignment\nRef: https://kubernetes.io/docs/concepts/configuration/assign-pod-node/#affinity-and-anti-affinity",
      "type": "object"
    },
    "envs": {
      "additionalProperties": false,
      "description": "configure UI ENVs",
      "properties": {
        "appUrl": {
          "description": "IMPORTANT: While operator chart and UI chart are independent, this is the interface between\nUI and operator API. Insert the service name of the operator API here!",
          "type": "string"
        },
        "operatorApiUrl": {
          "type": "string"
        },
        "operatorClusterNameLabel": {
          "type": "string"
        },
        "resourcesVisible": {
          "type": "string"
        },
        "targetNamespace": {
          "description": "Set to \"*\" to allow viewing/creation of clusters in all namespaces",
          "type": "string"
        },
        "teams": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "extraEnvs": {
      "anyOf": [
        {
          "items": {},
          "type": "array"
        },
        {
          "type": "null"
        },
        {
          "type": "string"
        }
      ],
      "description": "configure extra UI ENVs\nExtra ENVs are writen in kubenertes format and added \"as is\" to the pod's env variables\nhttps://kubernetes.io/docs/tasks/inject-data-application/define-environment-variable-container/\nhttps://kubernetes.io/docs/reference/kubernetes-api/workload-resources/pod-v1/#environment-variables\nUI specific env variables can be found here: https://github.com/zalando/postgres-operator/blob/master/ui/operator_ui/main.py"
    },
    "fullnameOverride": {
      "type": [
        "string",
        "null"
      ]
    },
    "image": {
      "additionalProperties": false,
      "description": "configure ui image",
      "properties": {
        "pullPolicy": {
          "type": "string"
        },
        "registry": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "imagePullSecrets": {
      "additionalProperties": {},
      "type": "object"
    },
    "ingress": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "$ref": "#/$defs/helm-truthy"
              }
            },
            "required": [
              "enabled"
            ],
            "type": "object"
          },
          "then": {
            "properties": {
              "annotations": {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              "ingressClassName": {
                "description": "kubernetes.io/ingress.class: nginx\nkubernetes.io/tls-acme: \"true\"",
                "type": "string"
              }
            },
            "type": "object"
          }
        }
      ],
      "description": "configure UI ingress. If needed: \"enabled: true\"",
      "properties": {
        "annotations": {
          "additionalProperties": {},
          "type": "object"
        },
        "enabled": {
          "type": "boolean"
        },
        "hosts": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "host": {
                "type": "string"
              },
              "paths": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "ingressClassName": {
          "description": "kubernetes.io/ingress.class: nginx\nkubernetes.io/tls-acme: \"true\""
        },
        "tls": {
          "description": "- secretName: ui-tls\nhosts:\n- ui.exmaple.org",
          "items": {
            "additionalProperties": false,
            "properties": {
              "hosts": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "secretName": {}
            },
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "nameOverride": {
      "type": [
        "string",
        "null"
      ]
    },
    "nodeSelector": {
      "additionalProperties": {},
      "description": "Node labels for pod assignment\nRef: https://kubernetes.io/docs/user-guide/node-selection/",
      "type": "object"
    },
    "podAnnotations": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Extra pod annotations",
      "type": "object"
    },
    "priorityClassName": {
      "description": "priority class for operator-ui pod",
      "type": [
        "string",
        "null"
      ]
    },
    "rbac": {
      "additionalProperties": false,
      "properties": {
        "create": {
          "description": "Specifies whether RBAC resources should be created",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "type": "integer"
    },
    "resources": {
      "additionalProperties": {
        "additionalProperties": {
          "type": "string"
        },
        "properties": {
          "cpu": {
            "type": "string"
          },
          "memory": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "description": "configure UI pod resources",
      "properties": {
        "limits": {
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "service": {
      "additionalProperties": false,
      "description": "configure UI service",
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "If the type of the service is NodePort a port can be specified using the nodePort field\nIf the nodePort field is not specified, or if it has no value, then a random port is used\nnodePort: 32521",
          "type": "object"
        },
        "nodePort": {},
        "port": {
          "type": "string"
        },
        "type": {
          "anyOf": [
            {
              "enum": [
                "NodePort"
              ]
            },
            {
              "type": "string"
            }
          ]
        }
      },
      "type": "object"
    },
    "serviceAccount": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "anyOf": [
              {
                "not": {
                  "properties": {
                    "create": {}
                  },
                  "required": [
                    "create"
                  ],
                  "type": "object"
                }
              },
              {
                "properties": {
                  "create": {
                    "$ref": "#/$defs/helm-truthy"
                  }
                },
                "required": [
                  "create"
                ],
                "type": "object"
              }
            ]
          },
          "then": {
            "properties": {
              "name": {
                "description": "The name of the ServiceAccount to use.\nIf not set and create is true, a name is generated using the fullname template",
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "type": "object"
          }
        }
      ],
      "properties": {
        "create": {
          "description": "Specifies whether a ServiceAccount should be created",
          "type": "boolean"
        },
        "name": {
          "description": "The name of the ServiceAccount to use.\nIf not set and create is true, a name is generated using the fullname template",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "tolerations": {
      "anyOf": [
        {
          "items": {},
          "type": "array"
        },
        {
          "type": "null"
        },
        {
          "type": "string"
        }
      ],
      "description": "Tolerations for pod assignment\nRef: https://kubernetes.io/docs/concepts/configuration/taint-and-toleration/"
    }
  },
  "type": "object"
}
